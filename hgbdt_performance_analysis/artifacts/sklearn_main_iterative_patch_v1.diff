+def _cap_threads_to_available_cpus(n_threads):
+    """Keep HistGB thread count bounded by available CPUs."""
+    try:
+        available_cpus = len(os.sched_getaffinity(0))
+    except (AttributeError, OSError):
+        available_cpus = os.cpu_count() or n_threads
+    return max(1, min(n_threads, available_cpus))
