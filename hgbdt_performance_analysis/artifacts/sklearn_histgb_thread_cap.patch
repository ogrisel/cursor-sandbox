+def _cap_threads_to_available_cpus(n_threads):
+    """Bound OpenMP thread requests to available CPUs.
+
+    HistGradientBoosting can regress badly when OpenMP is oversubscribed
+    (e.g. 16 threads on 4 CPUs). Capping requested threads to available CPUs
+    avoids excessive scheduling and synchronization overhead in that regime.
+    """
+    if hasattr(os, "sched_getaffinity"):
+        available_cpus = len(os.sched_getaffinity(0))
+    else:
+        available_cpus = os.cpu_count()
+    if available_cpus is None:
+        return n_threads
+    return max(1, min(n_threads, available_cpus))
+
